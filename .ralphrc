# .ralphrc - Ralph project configuration
# Generated by: ralph enable
# Documentation: https://github.com/frankbria/ralph-claude-code

# Project identification
PROJECT_NAME="tapps-brain"
PROJECT_TYPE="python"

# Claude Code CLI command
# If "claude" is not in your PATH, set to your installation:
#   "npx @anthropic-ai/claude-code"  (uses npx, no global install needed)
#   "/path/to/claude"                (custom path)
CLAUDE_CODE_CMD="claude"

# Loop settings
MAX_CALLS_PER_HOUR=100
CLAUDE_TIMEOUT_MINUTES=30
CLAUDE_OUTPUT_FORMAT="json"

# Tool permissions
# Comma-separated list of allowed tools
# Safe git subcommands only - broad Bash(git *) allows destructive commands like git clean/git rm (Issue #149)
ALLOWED_TOOLS="Write,Read,Edit,Glob,Grep,TodoWrite,WebFetch,Bash(git add *),Bash(git -C *),Bash(git commit *),Bash(git diff *),Bash(git log *),Bash(git status),Bash(git status *),Bash(git push *),Bash(git pull *),Bash(git fetch *),Bash(git checkout *),Bash(git branch *),Bash(git stash *),Bash(git merge *),Bash(git tag *),Bash(grep *),Bash(uv *),Bash(pip *),Bash(python *),Bash(python3 *),Bash(pytest *),Bash(pytest),Bash(ruff *),Bash(mypy *),Bash(ls *),Bash(cat *),Bash(mkdir *),Bash(cp *),Bash(mv *),Bash(head *),Bash(tail *),Bash(wc *),Bash(find *),Bash(which *),Bash(echo *),Bash(xargs *),Bash(sort *),Bash(tee *),Bash(rm *),Bash(touch *),Bash(sed *),Bash(awk *),Bash(tr *),Bash(cut *),Bash(dirname *),Bash(basename *),Bash(realpath *),Bash(test *),Bash(true),Bash(false),Bash(sleep *)"

# Session management
# false = fresh context per loop (patched ralph_loop.sh line 1342 to fix live mode extraction)
SESSION_CONTINUITY=false
SESSION_EXPIRY_HOURS=24

# Task sources (for ralph enable --sync)
# Options: local, beads, github (comma-separated for multiple)
TASK_SOURCES="github,local"
GITHUB_TASK_LABEL="ralph-task"
BEADS_FILTER="status:open"

# Circuit breaker thresholds
CB_NO_PROGRESS_THRESHOLD=3
CB_SAME_ERROR_THRESHOLD=5
CB_OUTPUT_DECLINE_THRESHOLD=70
CB_AUTO_RESET=true
CB_COOLDOWN_MINUTES=10

# Log rotation (v1.1.0)
LOG_MAX_SIZE_MB=10
LOG_MAX_FILES=5
LOG_MAX_OUTPUT_FILES=20

# Dry-run mode (v1.1.0) — preview execution without API calls
# Also activatable via: ralph --dry-run
DRY_RUN=false

# Auto-update Claude CLI at startup
CLAUDE_AUTO_UPDATE=true

# Agent mode (v1.0+): use --agent ralph instead of -p with --allowedTools
# Requires CLI v2.1+. Falls back to legacy -p mode if unsupported.
RALPH_USE_AGENT=true
RALPH_AGENT_NAME="ralph"

# Parallelism (v1.1.0 — Experimental)
RALPH_ENABLE_TEAMS=false
RALPH_MAX_TEAMMATES=3
RALPH_BG_TESTING=false
RALPH_TEAMMATE_MODE="tmux"
