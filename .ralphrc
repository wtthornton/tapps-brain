# .ralphrc - Ralph project configuration
# Generated by: ralph enable
# Documentation: https://github.com/frankbria/ralph-claude-code

# Force Max-plan OAuth auth — defensive against ANTHROPIC_API_KEY leaking in
# from this repo's .env (used by STORY-SC01 benchmarks). Today's Claude Code
# CLI prefers OAuth over the env API key, but `claude --bare`, future CLI
# precedence changes, or `ralph --sandbox` would route around Max plan billing.
unset ANTHROPIC_API_KEY
unset ANTHROPIC_AUTH_TOKEN

# Project identification
PROJECT_NAME="tapps-brain"
PROJECT_TYPE="python"

# Claude Code CLI command
# If "claude" is not in your PATH, set to your installation:
#   "npx @anthropic-ai/claude-code"  (uses npx, no global install needed)
#   "/path/to/claude"                (custom path)
CLAUDE_CODE_CMD="claude"

# Loop settings
MAX_CALLS_PER_HOUR=100
CLAUDE_TIMEOUT_MINUTES=35
RALPH_SDK_MAX_TURNS=100
CLAUDE_OUTPUT_FORMAT="json"

# Tool permissions
# ALLOWED_TOOLS is commented out to enable agent mode (RALPH_USE_AGENT=true).
# When ALLOWED_TOOLS is set, ralph auto-disables agent mode and falls back to legacy
# -p mode, which blocks MCP tools (tapps-mcp, docs-mcp) and sub-agents.
# Destructive commands are blocked via disallowedTools in .claude/agents/ralph.md instead.
# ALLOWED_TOOLS="..."

# Session management
# false = fresh context per loop (patched ralph_loop.sh line 1342 to fix live mode extraction)
SESSION_CONTINUITY=false  # Token optimization: each loop self-contained (no 2.8M-token cache reload). One story per loop.
SESSION_EXPIRY_HOURS=24

# Task sources (for ralph enable --sync)
# Options: local, beads, github (comma-separated for multiple)
TASK_SOURCES="github,local"
GITHUB_TASK_LABEL="ralph-task"
BEADS_FILTER="status:open"

# Circuit breaker thresholds
CB_NO_PROGRESS_THRESHOLD=3
CB_SAME_ERROR_THRESHOLD=5
CB_OUTPUT_DECLINE_THRESHOLD=70
CB_AUTO_RESET=true
CB_COOLDOWN_MINUTES=10

# Log rotation (v1.1.0)
LOG_MAX_SIZE_MB=10
LOG_MAX_FILES=5
LOG_MAX_OUTPUT_FILES=20

# Dry-run mode (v1.1.0) — preview execution without API calls
# Also activatable via: ralph --dry-run
DRY_RUN=false

# Auto-update Claude CLI at startup
CLAUDE_AUTO_UPDATE=false  # set false — npm global update fails on this machine (see bottom of file)

# Agent mode (v1.0+): use --agent ralph instead of -p with --allowedTools
# Requires CLI v2.1+. Falls back to legacy -p mode if unsupported.
RALPH_USE_AGENT=true
RALPH_AGENT_NAME="ralph"

# Parallelism (v1.1.0 — Experimental)
RALPH_ENABLE_TEAMS=true
RALPH_MAX_TEAMMATES=3
RALPH_BG_TESTING=false
RALPH_TEAMMATE_MODE="tmux"

# =============================================================================
# ADVANCED SETTINGS
# =============================================================================

# Model to use for Ralph loops (default: uses Claude Code's default)
# Examples: claude-sonnet-4-6, claude-opus-4-6
CLAUDE_MODEL="claude-sonnet-4-6"  # Token optimization: main loop on Sonnet (~5x cheaper than Opus). ralph-architect agent stays on Opus for LARGE/architectural tasks.

# Effort level for Ralph loops (default: uses agent definition or Claude default)
# Options: low, medium, high
# CLAUDE_EFFORT=""

# Auto-update Claude CLI at startup (checks npm registry, attempts npm update -g)
# Recommended: true for local workstations and home servers (keeps CLI current automatically)
# Recommended: false for Docker containers (version is pinned at image build, container is ephemeral)
# Also set false for air-gapped environments without npm registry access
# Disabled: npm global update fails on this machine due to permissions — update manually
CLAUDE_AUTO_UPDATE=false

# Minimum Claude CLI version required
CLAUDE_MIN_VERSION="2.0.76"

# Enable verbose logging
RALPH_VERBOSE=false

# Agent mode (v1.0+): use --agent ralph instead of -p with --allowedTools
# When true, uses .claude/agents/ralph.md agent definition (requires CLI v2.1+)
# Falls back to legacy -p mode if CLI does not support --agent
# NOTE (Issue #154): Agent mode is also auto-disabled when ALLOWED_TOOLS is
# customized above, because agent mode uses a blocklist (disallowedTools) which
# is incompatible with the allowlist approach. See TOOL PERMISSIONS section.
RALPH_USE_AGENT=true
RALPH_AGENT_NAME="ralph"

# Custom prompt file (relative to .ralph/)
# PROMPT_FILE="PROMPT.md"

# Custom fix plan file (relative to .ralph/)
# FIX_PLAN_FILE="@fix_plan.md"

# Custom agent file (relative to .ralph/)
# AGENT_FILE="@AGENT.md"
# =============================================================================
# PLAN OPTIMIZATION (PLANOPT epic)
# =============================================================================

# Disable automatic plan optimization on session start
# When true, fix_plan.md is never reordered by the optimizer
RALPH_NO_OPTIMIZE=false

# Disable ralph-explorer resolution of vague tasks (tasks with no file paths)
# When true, tasks without explicit file references are left as-is
RALPH_NO_EXPLORER_RESOLVE=false

# Maximum vague tasks to resolve per optimization run
# Caps explorer calls to stay within the ContextManager visible window
RALPH_MAX_EXPLORER_RESOLVE=5
# =============================================================================
# CONTEXT MANAGEMENT (Phase 14)
# =============================================================================

# Enable progressive context loading to reduce token usage per iteration
# When enabled, only the current epic and next N unchecked items are injected
RALPH_PROGRESSIVE_CONTEXT=true

# Maximum unchecked plan items to include in progressive context
RALPH_MAX_PLAN_ITEMS=10
# =============================================================================
# COST OPTIMIZATION (Phase 14)
# =============================================================================

# Prompt cache optimization — structure prompts for maximum cache hits
RALPH_PROMPT_CACHE_ENABLED=true

# Cost budget in USD (0 = no budget limit)
# RALPH_COST_BUDGET_USD=0
# =============================================================================
# OPENTELEMETRY EXPORT (Phase 14)
# =============================================================================

# OTLP HTTP endpoint for trace export (e.g., http://localhost:4318/v1/traces)
# RALPH_OTLP_ENDPOINT=""

# Enable OTLP trace export to external backend
# RALPH_OTLP_EXPORT_ENABLED=false

# Monthly cost budget in USD (0 = disabled, triggers alert at 80% by default)
# RALPH_COST_BUDGET_USD=0
# =============================================================================
