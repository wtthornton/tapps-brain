# tapps-brain environment variable template
#
# Copy to .env and fill in your values.
# Full reference: docs/guides/postgres-dsn.md
#
# Do NOT commit a populated .env to version control.

# ---------------------------------------------------------------------------
# Identity & paths (required in every environment)
# ---------------------------------------------------------------------------

TAPPS_BRAIN_AGENT_ID=my-agent
TAPPS_BRAIN_PROJECT_DIR=/path/to/your/project

# ---------------------------------------------------------------------------
# Postgres DSNs (v3 — all three may point to the same database in dev)
# ---------------------------------------------------------------------------

# Unified v3 DSN — private memory + Hive fallback
TAPPS_BRAIN_DATABASE_URL=postgres://tapps:tapps@localhost:5432/tapps

# Hive shared-store DSN (cross-agent memory sharing)
TAPPS_BRAIN_HIVE_DSN=postgres://tapps:tapps@localhost:5432/tapps_hive

# Cross-project Federation DSN (omit if not using federation)
# TAPPS_BRAIN_FEDERATION_DSN=postgres://tapps:tapps@localhost:5432/tapps_fed

# ---------------------------------------------------------------------------
# Migrations & strict mode
# ---------------------------------------------------------------------------

# Apply pending schema migrations on startup (set true on first deploy)
TAPPS_BRAIN_HIVE_AUTO_MIGRATE=true

# Fail fast if DSN is missing (recommended for production; omit for dev)
TAPPS_BRAIN_STRICT=1

# ---------------------------------------------------------------------------
# Connection pool sizing (defaults work for most cases)
# ---------------------------------------------------------------------------

# TAPPS_BRAIN_HIVE_POOL_MIN=2
# TAPPS_BRAIN_HIVE_POOL_MAX=10
# TAPPS_BRAIN_HIVE_CONNECT_TIMEOUT=5
# TAPPS_BRAIN_HIVE_POOL_IDLE_TIMEOUT=300

# ---------------------------------------------------------------------------
# Groups & expert domains (optional — for multi-agent Hive routing)
# ---------------------------------------------------------------------------

# TAPPS_BRAIN_GROUPS=dev-pipeline,frontend-guild
# TAPPS_BRAIN_EXPERT_DOMAINS=css,react

# ---------------------------------------------------------------------------
# HTTP adapter auth (required if running the HTTP adapter in production)
# ---------------------------------------------------------------------------

# TAPPS_BRAIN_HTTP_AUTH_TOKEN=change-me-in-production

# ---------------------------------------------------------------------------
# MCP operator tools (enable only in dedicated maintenance sessions)
# ---------------------------------------------------------------------------

# TAPPS_BRAIN_OPERATOR_TOOLS=1
