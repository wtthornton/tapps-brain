{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus datasource scraping the tapps-brain /metrics endpoint.",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "table",
      "name": "Table",
      "version": ""
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Per-tenant observability for tapps-brain shared deployments (STORY-070.12). Shows per-project_id request rates, tool call breakdown, error rates, and latency.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Request Volume",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (project_id) (rate(tapps_brain_mcp_requests_total{project_id=~\"$project_id\"}[$__rate_interval]))",
          "legendFormat": "{{project_id}}",
          "refId": "A"
        }
      ],
      "title": "MCP Requests/s by Project",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 2,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (agent_id) (rate(tapps_brain_mcp_requests_total{project_id=~\"$project_id\"}[$__rate_interval]))",
          "legendFormat": "{{agent_id}}",
          "refId": "A"
        }
      ],
      "title": "MCP Requests/s by Agent",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101,
      "title": "Tool Call Breakdown",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 3,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (tool) (rate(tapps_brain_tool_calls_total{project_id=~\"$project_id\",status=\"success\"}[$__rate_interval]))",
          "legendFormat": "{{tool}}",
          "refId": "A"
        }
      ],
      "title": "Tool Call Rate by Tool (success)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" },
          "custom": { "lineWidth": 2 },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 4,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (tool, project_id) (rate(tapps_brain_tool_calls_total{project_id=~\"$project_id\",status=\"error\"}[$__rate_interval]))",
          "legendFormat": "{{project_id}}/{{tool}}",
          "refId": "A"
        }
      ],
      "title": "Tool Error Rate by Project + Tool",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 102,
      "title": "Error Rates",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 19 },
      "id": 5,
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (project_id) (rate(tapps_brain_tool_calls_total{project_id=~\"$project_id\",status=\"error\"}[$__rate_interval])) / sum by (project_id) (rate(tapps_brain_tool_calls_total{project_id=~\"$project_id\"}[$__rate_interval]))",
          "legendFormat": "{{project_id}}",
          "refId": "A"
        }
      ],
      "title": "Error Rate by Project",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 },
      "id": 103,
      "title": "Agent Activity Table",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto" } }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 26 },
      "id": 6,
      "options": {
        "footer": { "show": false },
        "sortBy": [{ "displayName": "Requests", "desc": true }]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (project_id, agent_id) (increase(tapps_brain_mcp_requests_total{project_id=~\"$project_id\"}[$__range]))",
          "legendFormat": "{{project_id}} / {{agent_id}}",
          "refId": "A",
          "instant": true
        }
      ],
      "title": "Requests per Project × Agent (window)",
      "transformations": [
        { "id": "labelsToFields", "options": {} },
        { "id": "organize", "options": { "renameByName": { "Value": "Requests" } } }
      ],
      "type": "table"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["tapps-brain", "observability", "multi-tenant"],
  "templating": {
    "list": [
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(tapps_brain_mcp_requests_total, project_id)",
        "hide": 0,
        "includeAll": true,
        "label": "Project",
        "multi": true,
        "name": "project_id",
        "options": [],
        "query": {
          "query": "label_values(tapps_brain_mcp_requests_total, project_id)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "tapps-brain — Per-Tenant Observability",
  "uid": "tapps-brain-per-tenant-v1",
  "version": 1
}
