# Copy to .env and fill in — consumed by brain_init.py

# Agent identity — used to scope private memories and attribute Hive writes.
TAPPS_BRAIN_AGENT_ID=my-app-agent

# Project root for in-process use. Defaults to cwd if unset.
TAPPS_BRAIN_PROJECT_DIR=.

# Explicit project_id for deployed/multi-tenant hubs. Must be pre-registered
# against the hub (see docs/guides/mcp.md → Project identity).
# TAPPS_BRAIN_PROJECT=my-project

# Hive DSN — Postgres shared-memory hub. Omit to run purely local/private.
TAPPS_BRAIN_HIVE_DSN=postgres://tapps:tapps@localhost:5433/tapps_hive

# Auto-migrate the private schema on first store open. Safe to leave on for dev.
TAPPS_BRAIN_AUTO_MIGRATE=1

# Optional — comma-separated Hive groups this agent is a member of.
# TAPPS_BRAIN_GROUPS=frontend-guild,infra
