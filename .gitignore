node_modules/

# LOCK-1: Instance lock file (auto-released by flock)
.ralph/.ralph.lock

# Local Mem0 checkout (not part of tapps-brain; do not commit)
mem0-review/

# Local Docker secrets (passwords); use docker/secrets/*.example in docs
docker/secrets/

# tapps-mcp CLI cache and session metrics (local only)
.tapps-mcp-cache/
