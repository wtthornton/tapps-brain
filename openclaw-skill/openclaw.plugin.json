{
  "name": "tapps-brain-memory",
  "version": "1.2.0",
  "displayName": "tapps-brain — Persistent Memory",
  "description": "ContextEngine plugin for tapps-brain: persistent cross-session memory with BM25 ranking, exponential decay, and multi-agent Hive sharing.",
  "slot": "ContextEngine",
  "install": {
    "pip": "tapps-brain[mcp]>=1.2.0"
  },
  "mcp": {
    "command": "tapps-brain-mcp",
    "transport": "stdio",
    "args": ["--project-dir", "${workspaceDir}"]
  },
  "hooks": [
    "bootstrap",
    "ingest",
    "afterTurn",
    "compact"
  ],
  "capabilities": {
    "recall": true,
    "capture": true,
    "compaction": true,
    "profiles": true,
    "hive": true,
    "federation": true
  },
  "settings": {
    "mcpCommand": "tapps-brain-mcp",
    "profilePath": ".tapps-brain/profile.yaml",
    "tokenBudget": 2000,
    "captureRateLimit": 3
  }
}
