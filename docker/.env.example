# docker/.env — secrets + overrides for the unified tapps-brain stack.
#
# Copy this file to `docker/.env` and fill in strong random values BEFORE
# running `docker compose -p tapps-brain -f docker/docker-compose.hive.yaml up`.
# The compose file will refuse to start if any required variable is unset.
#
# DO NOT commit your docker/.env file — it is gitignored alongside the repo
# root .env (see .gitignore).

# ---------------------------------------------------------------------------
# REQUIRED — fill in before first `docker compose up`
# ---------------------------------------------------------------------------

# Postgres password for the `tapps` owner role on the brain DB container.
# This role runs DDL during the one-shot migrate sidecar only — the live
# brain container does NOT use this password.
# Generate with:  openssl rand -base64 32
TAPPS_BRAIN_DB_PASSWORD=REPLACE_ME_openssl_rand_base64_32

# Postgres password for the `tapps_runtime` DML-only role. The brain container
# connects as this role — no DDL, no BYPASSRLS, no table ownership. Created
# and grant-wired by the migrate sidecar (idempotent; re-running rolls it).
# Generate with:  openssl rand -base64 32
TAPPS_BRAIN_RUNTIME_PASSWORD=REPLACE_ME_openssl_rand_base64_32

# Bearer token that clients (IDE MCP clients, AgentBrain, AgentForge, etc.)
# present to the brain's data plane at :8080 — sent as `Authorization: Bearer <token>`
# along with `X-Project-Id`. Generate with:  openssl rand -hex 32
TAPPS_BRAIN_AUTH_TOKEN=REPLACE_ME_openssl_rand_hex_32

# Admin token for the operator MCP transport at :8090 (loopback-only by
# default). The operator transport refuses to start without this.
# Generate with:  openssl rand -hex 32
TAPPS_BRAIN_ADMIN_TOKEN=REPLACE_ME_openssl_rand_hex_32

# ---------------------------------------------------------------------------
# OPTIONAL — tweak only if you have a specific reason
# ---------------------------------------------------------------------------

# Comma-separated CORS origins for the /snapshot endpoint (default: empty —
# all origins accepted, which is fine for local dev but NOT for production).
# TAPPS_BRAIN_ALLOWED_ORIGINS=https://dashboard.example.com,https://ide.example.com

# Host ports (defaults shown). Override if 8080/8088/8090 conflict on your host.
# TAPPS_HTTP_PORT=8080
# TAPPS_VISUAL_PORT=8088
# TAPPS_OPERATOR_MCP_PORT=8090

# Operator MCP bind address. Default is 127.0.0.1 so :8090 isn't exposed to
# the network. Set to 0.0.0.0 only if you're fronting the operator transport
# behind a reverse proxy with additional auth.
# TAPPS_OPERATOR_MCP_BIND=127.0.0.1
