{
  "name": "@tapps-brain/sdk",
  "version": "1.0.0",
  "description": "TypeScript SDK for tapps-brain persistent agent memory",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:contract": "TAPPS_BRAIN_CONTRACT=1 vitest run tests/contract.test.ts"
  },
  "keywords": [
    "tapps-brain",
    "memory",
    "ai",
    "agent",
    "sdk",
    "mcp",
    "langgraph"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wtthornton/tapps-brain.git",
    "directory": "packages/sdk"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/",
    "README.md"
  ]
}
