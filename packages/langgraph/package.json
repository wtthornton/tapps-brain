{
  "name": "@tapps-brain/langgraph",
  "version": "1.0.0",
  "description": "LangGraph BaseStore adapter backed by tapps-brain persistent memory",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit",
