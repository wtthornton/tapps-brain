      "optional": false
    }
  },
  "devDependencies": {
    "@tapps-brain/sdk": "*",
    "@langchain/langgraph": "^0.2.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
