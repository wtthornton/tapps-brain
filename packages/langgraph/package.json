  },
  "keywords": [
    "tapps-brain",
    "langgraph",
    "langchain",
    "memory",
    "ai",
    "agent",
    "store"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wtthornton/tapps-brain.git",
    "directory": "packages/langgraph"
  },
  "dependencies": {
    "@tapps-brain/sdk": "^1.0.0"
  },
  "peerDependencies": {
