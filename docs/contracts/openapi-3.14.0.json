{
  "components": {
    "parameters": {
      "XAgentId": {
        "description": "Per-call agent identity.  Defaults to ``\"unknown\"`` when omitted.  Threaded into RLS as ``app.agent_id``.",
        "in": "header",
        "name": "X-Agent-Id",
        "required": false,
        "schema": {
          "default": "unknown",
          "type": "string"
        }
      },
      "XIdempotencyKey": {
        "description": "Idempotency key (UUID).  When ``TAPPS_BRAIN_IDEMPOTENCY=1`` a duplicate key within 24 h replays the original response with header ``Idempotency-Replayed: true``.",
        "in": "header",
        "name": "X-Idempotency-Key",
        "required": false,
        "schema": {
          "format": "uuid",
          "type": "string"
        }
      },
      "XProjectId": {
        "description": "Tenant identity (ADR-010).  Required on every data-plane and MCP request; the brain isolates state by ``(project_id, agent_id)``.",
        "in": "header",
        "name": "X-Project-Id",
        "required": true,
        "schema": {
          "minLength": 1,
          "type": "string"
        }
      },
      "XTappsAgent": {
        "description": "Optional agent fingerprint string used for telemetry labelling.  Distinct from ``X-Agent-Id``.",
        "in": "header",
        "name": "X-Tapps-Agent",
        "required": false,
        "schema": {
          "type": "string"
        }
      }
    },
    "schemas": {
      "Error": {
        "properties": {
          "detail": {
            "description": "Human-readable explanation; not machine-stable.",
            "type": "string"
          },
          "error": {
            "description": "Taxonomy code (see ``tapps_brain.errors``).  Stable wire identifier \u2014 clients map this to retry policy.",
            "examples": [
              "bad_request",
              "unauthorized",
              "forbidden",
              "payload_too_large",
              "store_unavailable",
              "admin_disabled"
            ],
            "type": "string"
          },
          "retry_after": {
            "description": "Seconds to wait before retry, present on rate-limited responses.",
            "type": "number"
          }
        },
        "required": [
          "error"
        ],
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "Info": {
        "properties": {
          "auth_enabled": {
            "type": "boolean"
          },
          "build": {
            "description": "Build identifier from ``TAPPS_BRAIN_BUILD`` env var; ``\"unknown\"`` outside of a built image.",
            "type": "string"
          },
          "dsn_configured": {
            "type": "boolean"
          },
          "platform": {
            "type": "string"
          },
          "python": {
            "type": "string"
          },
          "schema_version": {
            "description": "Bundled private-schema migration version.",
            "type": "integer"
          },
          "service": {
            "type": "string"
          },
          "uptime_seconds": {
            "type": "number"
          },
          "version": {
            "description": "Brain code version (PEP 440).",
            "type": "string"
          }
        },
        "required": [
          "service",
          "version",
          "schema_version",
          "build"
        ],
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      }
    },
    "securitySchemes": {
      "adminBearerAuth": {
        "description": "Admin bearer token for ``/admin/*`` routes.  Set ``TAPPS_BRAIN_ADMIN_TOKEN``; when unset, ``/admin/*`` returns 503.",
        "scheme": "bearer",
        "type": "http"
      },
      "bearerAuth": {
        "description": "Data-plane bearer token.  Set ``TAPPS_BRAIN_AUTH_TOKEN`` (or per-tenant token via ``TAPPS_BRAIN_PER_TENANT_AUTH=1``) to enable.  When unset, protected routes are open (not-for-production).",
        "scheme": "bearer",
        "type": "http"
      }
    }
  },
  "info": {
    "description": "HTTP + MCP contract for the tapps-brain memory service (ADR-007 Postgres-only, ADR-010 multi-tenant project_id).\n\n**Transport.**  REST data plane (``/v1/*``, ``/snapshot``, ``/info``) and admin plane (``/admin/*``) use bearer-token auth; the MCP transport at ``/mcp`` uses the same data-plane token plus ``X-Project-Id``.\n\n**Tenancy.**  Every data-plane and MCP request must carry ``X-Project-Id`` (ADR-010); ``X-Agent-Id`` is optional and defaults to ``\"unknown\"``.\n\n**Errors.**  All error responses share the envelope ``{\"error\": <taxonomy_code>, \"detail\": <text>}``; see ``tapps_brain.errors`` for the canonical code list.",
    "title": "tapps-brain HTTP API",
    "version": "3.14.0",
    "x-schema-version": 15
  },
  "openapi": "3.1.0",
