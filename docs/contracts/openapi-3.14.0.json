    "/v1/forget": {
      "post": {
        "description": "Archive a memory by key.\n\nREST counterpart of the ``brain_forget`` MCP tool. The entry is\narchived (status flip), not permanently deleted.\n\nAccepts ``X-Idempotency-Key`` (UUID) when ``TAPPS_BRAIN_IDEMPOTENCY=1``.\nA duplicate key within 24 h replays the original response.\n\nRequest headers:\n  - ``X-Project-Id`` (required): project identifier.\n  - ``X-Agent-Id`` (optional, default ``\"unknown\"``): agent identifier.\n  - ``X-Idempotency-Key`` (optional): idempotency UUID.\n\nRequest body (JSON): ``{ \"key\": str }``\n\nResponse: ``{ \"forgotten\": bool, \"key\": str, \"reason\"?: str }``",
        "operationId": "_v1_forget_v1_forget_post",
        "parameters": [
          {
            "$ref": "#/components/parameters/XProjectId"
          },
          {
            "$ref": "#/components/parameters/XAgentId"
          },
          {
            "$ref": "#/components/parameters/XTappsAgent"
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "description": "Successful Response"
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            },
            "description": "Missing/malformed Authorization header."
          },
          "403": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            },
            "description": "Invalid token."
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": " V1 Forget"
      }
    },
