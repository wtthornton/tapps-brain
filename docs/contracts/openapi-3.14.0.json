    "/v1/learn_success": {
      "post": {
        "description": "Record a successful task outcome.\n\nREST counterpart of the ``brain_learn_success`` MCP tool.\n\nAccepts ``X-Idempotency-Key`` (UUID) when ``TAPPS_BRAIN_IDEMPOTENCY=1``.\n\nRequest headers:\n  - ``X-Project-Id`` (required): project identifier.\n  - ``X-Agent-Id`` (optional, default ``\"unknown\"``): agent identifier.\n  - ``X-Idempotency-Key`` (optional): idempotency UUID.\n\nRequest body (JSON): ``{ \"task_description\": str, \"task_id\"?: str }``\n\nResponse: ``{ \"learned\": true, \"key\": str }``",
        "operationId": "_v1_learn_success_v1_learn_success_post",
        "parameters": [
          {
            "$ref": "#/components/parameters/XProjectId"
          },
          {
            "$ref": "#/components/parameters/XAgentId"
          },
          {
            "$ref": "#/components/parameters/XTappsAgent"
          }
        ],
        "responses": {
          "200": {
